{
  "private": false,
  "name": "ts-seed",
  "version": "0.0.0",
  "author": "Kristof Mattei",
  "license": "MIT",
  "description": "TS Seed Project",
  "type": "module",
  "main": "dist/index.js",
  "packageManager": "pnpm@10.32.1+sha512.a706938f0e89ac1456b6563eab4edf1d1faf3368d1191fc5c59790e96dc918e4456ab2e67d613de1043d2e8c81f87303e6b40d4ffeca9df15ef1ad567348f2be",
  "engines": {
    "node": "24.14.0",
    "pnpm": "10.32.1"
  },
  "scripts": {
    "debug": "vite-node --inspect=0.0.0.0:9229 src/index.ts",
    "debug:watch": "vite-node --inspect=0.0.0.0:9229 --watch src/index.ts",
    "build": "vite build",
    "lint": "eslint . --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "pnpm run lint --fix",
    "format": "prettier --write .",
    "test": "vitest --coverage.enabled=true",
    "deps:ci": "depcruise --config dependency-cruiser.config.mjs --output-type err src",
    "deps:graph": "depcruise --config dependency-cruiser.config.mjs --output-type dot src | dot -T svg > dependency-graph.svg",
    "deps:report": "depcruise --config dependency-cruiser.config.mjs --output-type err-html --output-to dependency-report.html src",
    "prepare": "husky",
    "start": "node -r source-map-support/register ./dist/index.js"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "depcruise --config dependency-cruiser.config.mjs --validate -- "
    ],
    "*": [
      "eslint -- ",
      "prettier --ignore-unknown --"
    ]
  },
  "dependencies": {
    "express": "5.2.1",
    "source-map-support": "0.5.21"
  },
  "devDependencies": {
    "@codecov/vite-plugin": "1.9.1",
    "@eslint-community/eslint-plugin-eslint-comments": "4.7.1",
    "@eslint/config-helpers": "0.5.3",
    "@eslint/js": "10.0.1",
    "@stylistic/eslint-plugin": "5.10.0",
    "@types/eslint": "9.6.1",
    "@types/express": "5.0.6",
    "@types/node": "24.12.0",
    "@types/semver": "7.7.1",
    "@types/source-map-support": "0.5.10",
    "@typescript-eslint/parser": "8.57.0",
    "@vitest/coverage-v8": "4.1.0",
    "@vitest/ui": "4.1.0",
    "dependency-cruiser": "17.3.9",
    "eslint": "10.0.3",
    "eslint-config-love": "151.0.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-import-resolver-node": "0.3.9",
    "eslint-import-resolver-typescript": "4.4.4",
    "eslint-plugin-import-x": "4.16.2",
    "eslint-plugin-n": "17.24.0",
    "eslint-plugin-perfectionist": "5.6.0",
    "eslint-plugin-prettier": "5.5.5",
    "eslint-plugin-promise": "7.2.1",
    "eslint-plugin-unicorn": "63.0.0",
    "husky": "9.1.7",
    "lint-staged": "16.4.0",
    "prettier": "3.8.1",
    "typescript": "5.9.3",
    "typescript-eslint": "8.57.0",
    "vite": "8.0.0",
    "vite-node": "6.0.0",
    "vite-plugin-checker": "0.12.0",
    "vite-plugin-dts": "4.5.4",
    "vite-tsconfig-paths": "6.1.1",
    "vitest": "4.1.0"
  },
  "pnpm": {
    "overrides": {
      "@codecov/vite-plugin>vite": "^8.0.0",
      "undici": "^7.24.3"
    }
  }
}
