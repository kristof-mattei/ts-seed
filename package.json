{
    "name": "ts-seed",
    "version": "0.0.0",
    "author": "Kristof Mattei",
    "license": "MIT",
    "description": "TS Seed Project",
    "type": "module",
    "main": "dist/index.js",
    "packageManager": "pnpm@10.33.2+sha512.a90faf6feeab71ad6c6e57f94e0fe1a12f5dcc22cd754db40ae9593eb6a3e0b6b12e3540218bb37ae083404b1f2ce6db2a4121e979829b4aff94b99f49da1cf8",
    "engines": {
        "node": "24.15.0",
        "pnpm": "10.33.2"
    },
    "scripts": {
        "debug": "vite-node --inspect=0.0.0.0:9229 src/index.ts",
        "debug:watch": "vite-node --inspect=0.0.0.0:9229 --watch src/index.ts",
        "build": "vite build",
        "lint": "eslint . --report-unused-disable-directives --max-warnings 0",
        "lint:fix": "pnpm run lint --fix",
        "format": "prettier --write .",
        "test": "vitest --coverage.enabled=true",
        "deps:ci": "depcruise --config dependency-cruiser.config.mjs --output-type err src",
        "deps:graph": "depcruise --config dependency-cruiser.config.mjs --output-type dot src | dot -T svg > dependency-graph.svg",
        "deps:report": "depcruise --config dependency-cruiser.config.mjs --output-type err-html --output-to dependency-report.html src",
        "prepare": "husky",
        "start": "node -r source-map-support/register ./dist/index.js"
    },
    "lint-staged": {
        "*.{ts,tsx}": [
            "eslint --",
            "depcruise --config dependency-cruiser.config.mjs --validate --"
        ],
        "*": [
            "prettier --ignore-unknown --"
        ]
    },
    "dependencies": {
        "express": "5.2.1",
        "source-map-support": "0.5.21",
        "tslib": "2.8.1"
    },
    "devDependencies": {
        "@codecov/vite-plugin": "2.0.1",
        "@eslint-community/eslint-plugin-eslint-comments": "4.7.1",
        "@eslint/config-helpers": "0.5.5",
        "@eslint/core": "1.2.1",
        "@eslint/js": "10.0.1",
        "@stylistic/eslint-plugin": "5.10.0",
        "@types/eslint": "9.6.1",
        "@types/express": "5.0.6",
        "@types/node": "24.12.2",
        "@types/semver": "7.7.1",
        "@types/source-map-support": "0.5.10",
        "@typescript-eslint/parser": "8.59.1",
        "@vitest/coverage-v8": "4.1.5",
        "@vitest/ui": "4.1.5",
        "dependency-cruiser": "17.3.10",
        "eslint": "10.3.0",
        "eslint-config-love": "153.0.0",
        "eslint-config-prettier": "10.1.8",
        "eslint-import-resolver-node": "0.3.10",
        "eslint-import-resolver-typescript": "4.4.4",
        "eslint-plugin-import-x": "4.16.2",
        "eslint-plugin-n": "17.24.0",
        "eslint-plugin-perfectionist": "5.9.0",
        "eslint-plugin-prettier": "5.5.5",
        "eslint-plugin-promise": "7.3.0",
        "eslint-plugin-unicorn": "64.0.0",
        "husky": "9.1.7",
        "jiti": "2.6.1",
        "lint-staged": "16.4.0",
        "prettier": "3.8.3",
        "prettier-plugin-sh": "0.18.1",
        "prettier-plugin-toml": "2.0.6",
        "typescript": "6.0.3",
        "typescript-eslint": "8.59.1",
        "vite": "8.0.10",
        "vite-node": "6.0.0",
        "vite-plugin-checker": "0.13.0",
        "vitest": "4.1.5"
    },
    "pnpm": {
        "overrides": {
            "@codecov/vite-plugin>vite": "$vite",
            "undici": "8.2.0"
        },
        "ignoredBuiltDependencies": [
            "unrs-resolver"
        ]
    }
}
