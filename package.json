{
    "name": "ts-seed",
    "version": "0.0.0",
    "author": "Kristof Mattei",
    "license": "MIT",
    "description": "TS Seed Project",
    "type": "module",
    "main": "dist/index.js",
    "packageManager": "pnpm@11.9.0+sha512.bd682d5d03fe525ef7c9fd6780c6884d1e756ac4c9c9fe00c538782824310dcf90e3ddc4f53835f06dfaebd5085e41855e0bcbb3b60de2ac5bbab89e5036f03b",
    "engines": {
        "node": "26.4.0",
        "pnpm": "11.9.0"
    },
    "scripts": {
        "debug": "vite-node src/index.ts",
        "debug:watch": "vite-node --watch src/index.ts",
        "build": "vite build",
        "lint": "eslint . --report-unused-disable-directives --max-warnings 0",
        "lint:fix": "pnpm run lint --fix",
        "format": "prettier --write .",
        "test": "vitest --coverage.enabled=true",
        "deps:ci": "depcruise --config dependency-cruiser.config.mjs --output-type err src",
        "deps:graph": "depcruise --config dependency-cruiser.config.mjs --output-type dot src | dot -T svg > dependency-graph.svg",
        "deps:report": "depcruise --config dependency-cruiser.config.mjs --output-type err-html --output-to dependency-report.html src",
        "start": "node -r source-map-support/register ./dist/index.js"
    },
    "lint-staged": {
        "*.{ts,tsx}": [
            "eslint --",
            "depcruise --config dependency-cruiser.config.mjs --validate --"
        ],
        "*": [
            "prettier --ignore-unknown --"
        ]
    },
    "dependencies": {
        "@fastify/type-provider-typebox": "6.1.0",
        "fastify": "5.9.0",
        "pino-pretty": "^13.1.3",
        "source-map-support": "0.5.21",
        "tslib": "2.8.1"
    },
    "devDependencies": {
        "@codecov/vite-plugin": "2.0.1",
        "@eslint-community/eslint-plugin-eslint-comments": "4.7.2",
        "@eslint/config-helpers": "0.6.0",
        "@eslint/core": "1.2.1",
        "@eslint/js": "10.0.1",
        "@stylistic/eslint-plugin": "5.10.0",
        "@types/eslint": "9.6.1",
        "@types/node": "26.0.1",
        "@types/semver": "7.7.1",
        "@types/source-map-support": "0.5.10",
        "@typescript-eslint/parser": "8.62.1",
        "@vitest/coverage-v8": "4.1.9",
        "@vitest/ui": "4.1.9",
        "dependency-cruiser": "18.0.0",
        "eslint": "catalog:default",
        "eslint-config-love": "154.0.0",
        "eslint-config-prettier": "10.1.8",
        "eslint-import-resolver-node": "0.4.0",
        "eslint-import-resolver-typescript": "4.4.5",
        "eslint-plugin-import-x": "4.17.1",
        "eslint-plugin-n": "18.2.1",
        "eslint-plugin-perfectionist": "5.9.1",
        "eslint-plugin-prettier": "5.5.6",
        "eslint-plugin-promise": "7.3.0",
        "eslint-plugin-unicorn": "69.0.0",
        "jiti": "2.7.0",
        "lint-staged": "17.0.8",
        "prettier": "3.9.4",
        "prettier-plugin-sh": "0.18.1",
        "prettier-plugin-toml": "2.0.6",
        "typescript": "6.0.3",
        "typescript-eslint": "8.62.1",
        "vite": "catalog:default",
        "vite-node": "6.0.0",
        "vite-plugin-checker": "0.14.4",
        "vitest": "4.1.9"
    }
}
